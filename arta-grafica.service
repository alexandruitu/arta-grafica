[Unit]
Description=Arta Grafica - Planificare Productie
After=network.target

[Service]
Type=simple
User=raspberry
WorkingDirectory=/home/raspberry/arta-grafica/backend
ExecStart=/home/raspberry/arta-grafica/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --workers 2
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
